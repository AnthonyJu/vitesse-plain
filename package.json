{
  "type": "module",
  "private": true,
  "packageManager": "pnpm@11.5.1",
  "scripts": {
    "dev": "vite",
    "lint": "eslint --fix \"src/**/*.{js,jsx,ts,tsx,vue}\"",
    "lint:style": "stylelint --fix \"src/**/*.{vue,scss}\"",
    "typecheck": "vue-tsc --noEmit",
    "build": "vite build",
    "build-zip": "vite build && pick-zip -d",
    "preview": "vite preview",
    "preview-https": "serve dist",
    "up": "taze major -I",
    "sizecheck": "npx vite-bundle-visualizer",
    "postinstall": "npx simple-git-hooks"
  },
  "dependencies": {
    "@vueuse/core": "^14.3.0",
    "axios": "^1.17.0",
    "element-plus": "^2.14.1",
    "mitt": "^3.0.1",
    "nprogress": "^0.2.0",
    "pinia": "^3.0.4",
    "pinia-plugin-persistedstate": "^4.7.1",
    "vue": "^3.5.35",
    "vue-router": "^5.1.0"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^9.0.0",
    "@anthony-ju/eslint-config": "^0.2.9",
    "@anthony-ju/stylelint-config": "^0.5.0",
    "@iconify-json/carbon": "^1.2.22",
    "@types/node": "^25.9.1",
    "@types/nprogress": "^0.2.3",
    "@unocss/eslint-config": "^66.7.0",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vitejs/plugin-vue-jsx": "^5.1.5",
    "@vue/runtime-dom": "^3.5.35",
    "beasties": "^0.4.2",
    "cross-env": "^10.1.0",
    "eslint": "^10.4.1",
    "eslint-plugin-format": "^2.0.1",
    "https-localhost": "^4.7.1",
    "lint-staged": "^17.0.7",
    "pick-zip": "^0.2.0",
    "picocolors": "^1.1.1",
    "pnpm": "^11.5.1",
    "sass": "^1.100.0",
    "simple-git-hooks": "^2.13.1",
    "stylelint": "^17.12.0",
    "taze": "^19.14.1",
    "typescript": "^6.0.3",
    "unocss": "^66.7.0",
    "unplugin-auto-import": "^21.0.0",
    "unplugin-element-plus": "^0.11.2",
    "unplugin-vue-components": "^32.1.0",
    "vite": "^8.0.16",
    "vite-bundle-visualizer": "^1.2.1",
    "vite-plugin-devtools-json": "^1.0.0",
    "vite-plugin-pwa": "^1.3.0",
    "vite-plugin-vue-devtools": "^8.1.2",
    "vite-plugin-vue-layouts": "^0.11.0",
    "vite-svg-loader": "^5.1.1",
    "vue-tsc": "^3.3.3"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm lint-staged",
    "commit-msg": "node scripts/verify-commit.js"
  },
  "lint-staged": {
    "*.{vue,scss}": "stylelint --fix",
    "*.{js,jsx,ts,tsx,vue}": "eslint --fix"
  }
}
